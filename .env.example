# PostgreSQL
POSTGRES_DB=patientvoice
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production

# DATABASE_URL pour le dev local (NestJS + Prisma CLI)
# Docker Compose construit sa propre URL avec db:5432 — cette variable est ignorée par le compose
DATABASE_URL=postgresql://postgres:changeme_in_production@localhost:5432/patientvoice

# App
PORT=3000
NODE_ENV=production

# Rate limiting
# THROTTLE_TTL: window in seconds — max THROTTLE_LIMIT requests per window (global)
# POST /forms has its own override: 5 req / 60s per IP
THROTTLE_TTL=60
THROTTLE_LIMIT=30

# Admin (⚠️ change en prod — générer le secret avec: openssl rand -base64 32)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_in_production
ADMIN_TOKEN_SECRET=generate_with_openssl_rand_base64_32
ADMIN_TOKEN_TTL_SECONDS=43200

# n8n (optionnel — si absent, le déclenchement de l'analyse IA est désactivé)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/patientvoice-analysis
N8N_CALLBACK_SECRET=generate_with_openssl_rand_base64_32
N8N_WEBHOOK_SECRET_KEY=your-header-name
N8N_WEBHOOK_SECRET=your-header-value
