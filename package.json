{
  "name": "patientvoice",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm --filter backend build && pnpm --filter frontend build-only",
    "lint": "pnpm -r lint",
    "type-check": "pnpm --filter frontend type-check",
    "dev:db": "sh start_local_db.sh",
    "db:push": "pnpm --filter backend db:push",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:seed": "pnpm --filter backend seed"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
