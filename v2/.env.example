# PostgreSQL
POSTGRES_DB=patientvoice
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production

# App
PORT=3000
NODE_ENV=production

# Rate limiting
# THROTTLE_TTL: window in seconds — max THROTTLE_LIMIT requests per window (global)
# POST /forms has its own override: 5 req / 60s per IP
THROTTLE_TTL=60
THROTTLE_LIMIT=30
